{
  "name": "trace-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Background event server and hook client for tracing Codex sessions to Braintrust.",
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx --watch src/index.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src scripts",
    "lint:fix": "biome lint --write src scripts",
    "format": "biome format --write src scripts",
    "check": "biome check src scripts"
  },
  "keywords": [
    "braintrust",
    "tracing",
    "observability",
    "codex",
    "hooks"
  ],
  "author": "Braintrust",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^24.3.0",
    "@yao-pkg/pkg": "^6.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "braintrust": "^3.17.0"
  }
}
