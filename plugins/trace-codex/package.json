{
  "name": "trace-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Background event server and hook client for tracing Codex sessions to Braintrust.",
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run --watch src/index.ts serve",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src scripts",
    "lint:fix": "biome lint --write src scripts",
    "format": "biome format --write src scripts",
    "check": "biome check src scripts"
  },
  "keywords": [
    "braintrust",
    "tracing",
    "observability",
    "codex",
    "hooks"
  ],
  "author": "Braintrust",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "braintrust": "^3.17.0"
  }
}
